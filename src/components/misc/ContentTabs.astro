---
// src/components/misc/ContentTabs.astro
---

<script>
    function initTabs() {
        document.querySelectorAll<HTMLInputElement>('.tab-radio').forEach(radio => {
            if (radio.dataset.tabInit) return;
            radio.dataset.tabInit = 'true';

            radio.addEventListener('change', (e) => {
                const target = e.target as HTMLInputElement;
                const tabIndex = target.id.split('-').pop();
                const container = target.closest('.tabs-container');

                if (!container) return;

                container.querySelectorAll('.tab-content').forEach(content => {
                    content.classList.remove('tab-content-active');
                });

                const active = container.querySelector(
                    `.tab-content[data-tab-index="${tabIndex}"]`
                );
                if (active) {
                    active.classList.add('tab-content-active');
                }
            });
        });
    }

    document.addEventListener('DOMContentLoaded', initTabs);
    document.addEventListener('swup:page:view', initTabs);
</script>

<style is:global>
    .tabs-container {
        margin: 1.5rem 0;
        border-radius: 0.75rem;
        overflow: hidden;
        background: var(--license-block-bg);
    }

    .tab-radio {
        display: none;
    }

    .tabs-header {
        display: flex;
        gap: 0;
        border-bottom: 1px solid oklch(var(--p) / 0.2);
    }

    .tab-button {
        padding: 0.75rem 1.25rem;
        cursor: pointer;
        font-weight: 500;
        color: oklch(var(--bc) / 0.6);
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
        margin-bottom: -1px;
    }

    .tab-button:hover {
        color: oklch(var(--bc) / 0.9);
        background: oklch(var(--p) / 0.05);
    }

    .tab-radio:checked + .tab-button {
        color: var(--primary);
        border-bottom-color: var(--primary);
        font-weight: 600;
    }

    .tabs-body {
        padding: 1rem 1.25rem;
    }

    .tab-content {
        display: none;
        opacity: 0;
        transform: translateY(8px);
    }

    .tab-content-active {
        display: block;
        animation: tabFadeIn 0.3s ease forwards;
    }

    @keyframes tabFadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .tab-content > *:first-child {
        margin-top: 0;
    }

    .tab-content > *:last-child {
        margin-bottom: 0;
    }
</style>